# ==============================================================================
# Common Environment Variables
# ==============================================================================

# директория с папкой huggingface
DOCKER_VOLUME_STORAGE=../data
# DOCKER_VOLUME_STORAGE=D:\models\docker-compose-webui-llm-examples\data

# уровень логгирования при запуске скриптов внутри контейнеров
# LOG_LEVEL=DEBUG

# установить адрес удаленного сервера если сервер запускается не локально
# LLM_BASE_URL=http://127.0.0.1:8080


# ==============================================================================
# vLLM Environment Variables
# https://docs.vllm.ai/en/stable/configuration/env_vars/
# ==============================================================================
# Enable Offline Mode for vLLM
# TRANSFORMERS_OFFLINE=1

# set logging level
# VLLM_LOGGING_LEVEL=DEBUG

VLLM_PORT=8080
# VLLM_PORT=8000


# ==============================================================================
# SGLang Environment Variables
# https://docs.sglang.io/references/environment_variables.html
# ==============================================================================
# HF_HUB_OFFLINE=1
# HF_TOKEN=""

SGLANG_PORT=8080
# SGLANG_PORT=30000


# ==============================================================================
# llama.cpp Environment Variables
# https://github.com/ggml-org/llama.cpp/blob/master/tools/server/README.md
# ==============================================================================
# LLAMA_ARG_HF_REPO=PaddlePaddle/PaddleOCR-VL-1.6-GGUF

LLAMA_ARG_MODEL=/models/PaddleOCR-VL-1.6-GGUF.gguf
LLAMA_ARG_MMPROJ=/models/PaddleOCR-VL-1.6-GGUF-mmproj.gguf

# LLAMA_ARG_CTX_SIZE=4096
# LLAMA_ARG_N_GPU_LAYERS=auto
# LLAMA_ARG_CACHE_TYPE_K=fp16
# LLAMA_ARG_CACHE_TYPE_V=fp16
# LLAMA_ARG_N_PARALLEL=-1

# LLAMA_CACHE="llama_cache"
# LLAMA_OFFLINE=1

# - 0: generic output
# - 1: error
# - 2: warning
# - 3: info
# - 4: trace (more info)
# - 5: debug
# (default: 3)
# LLAMA_ARG_LOG_VERBOSITY=3

LLAMA_ARG_PORT=8080


# ==============================================================================
# Paddle Environment Variables
# ==============================================================================

# бэкенд (vllm, fastdeploy)
VLM_BACKEND=vllm

# тэг образа пайплайна и сервера для архитектуры Blackwell
# https://www.paddleocr.ai/latest/en/version3.x/pipeline_usage/PaddleOCR-VL-NVIDIA-Blackwell.html
API_IMAGE_TAG_SUFFIX=latest-nvidia-gpu-sm120-offline
VLM_IMAGE_TAG_SUFFIX=latest-nvidia-gpu-sm120-offline

# тэг образов пайплайна и сервера для архитектур, отличных от Blackwell
# API_IMAGE_TAG_SUFFIX=latest-nvidia-gpu-offline
# VLM_IMAGE_TAG_SUFFIX=latest-nvidia-gpu-offline

# отключить проверку подключения к хостингам моделей (HF, modelscope и др.)
PADDLE_PDX_DISABLE_MODEL_SOURCE_CHECK=true
# название основной модели OCR
PADDLEOCRVL_MODEL_NAME=PaddleOCR-VL-1.6-0.9B

PADDLE_PORT=8080
# PADDLE_PORT=8118


# ==============================================================================
# флаги чтобы модель PaddleOCRVL потребляла меньше памяти
# https://www.paddlepaddle.org.cn/documentation/docs/en/guides/flags/memory_en.html
# ==============================================================================

# стартегия аллоцирования памяти
FLAGS_allocator_strategy=naive_best_fit
# FLAGS_allocator_strategy=auto_growth

# начальный процент памяти графического процессора (по умолчанию в Win 0.5, в Linux 0.92)
# влияет только первоначальное выделение памяти - не ограничивает процент жестко
FLAGS_fraction_of_gpu_memory_to_use=0.5
# включить сборку мусора для экономии памяти
FLAGS_eager_delete_tensor_gb=0.0
